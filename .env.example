# Secrets for compose.yaml; copy to .env and fill in.
# Postgres credentials live separately in docker/postgres/.env.example.
# Reference only — no container reads this; nginx/certbot are configured
# on the host outside this repo. Kept here so you remember the value.
DOMAIN=alice.example.com
WEBHOOK_SECRET=long-random-string
DEEPSEEK_API_KEY=sk-...
# Optional: host port the app binds to (default 8090).
# APP_PORT=8090
